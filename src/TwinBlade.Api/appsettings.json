{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host={DB_Host};Port=5432;Database=postgres;Username=postgres;Password={DB_PASSWORD};SSL Mode=VerifyFull;Root Certificate=./global-bundle.pem"
  },

  "S3": {
    "BucketName": "",
    "Region": "",
    "BaseUrl": "",
    "AvatarPathPrefix": "",
    "DefaultAvatarFileName": "",
    "ItemPathPrefix": ""
  },

  "Cognito": {
    "UserPoolId": "",
    "ClientId": "",
    "Region": ""
  },

  "Cache": {
    "CacheEndpoint": "",
    "Ssl": false,
    "ConnectTimeoutMs": 5000,
    "SyncTimeoutMs": 5000,
    "AbortOnConnectFail": false
  },

  "Redis": {
    "Configuration": "",
    "RoomKeyPrefix": "room:"
  }
}
